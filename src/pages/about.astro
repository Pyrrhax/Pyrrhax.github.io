---
import BaseLayout from '../layouts/BaseLayout.astro';

const profileItems = [
  {
    title: '技术底色',
    text: '我有 Web2 开发、渗透测试和信息安全管理经验。技术对我来说不是身份标签，而是一种理解系统、拆解问题、验证现实的工具。',
  },
  {
    title: '长期关注',
    text: '我关注技术周期中个体能力的迁移：如何把安全经验、投资判断、AI 工具和内容表达，逐步沉淀为更稳定的个人系统。',
  },
];

const focusItems = [
  {
    title: 'Web3 与安全',
    text: '我关注 Web3 的长期价值，也在学习智能合约安全、区块链安全和真实漏洞案例，尝试把已有的安全经验迁移到新的技术系统中。',
  },
  {
    title: 'AI 与个人杠杆',
    text: 'AI 对我而言不是替代思考的工具，而是放大表达、开发、研究和整理能力的杠杆。我正在把 AI 融入写作、博客、项目开发和知识管理流程。',
  },
  {
    title: '投资与长期主义',
    text: '我关注投资，不只是为了收益，也是在学习如何理解周期、风险和选择权。比起短期结果，我更在意能否建立长期、稳健的判断框架。',
  },
];

const growthItems = [
  {
    stage: '2014',
    title: '从开发进入技术世界',
    text: '2014 年，我从 Web2 开发进入技术行业。那段经历让我第一次理解，许多复杂流程都可以被技术重新组织，也让我形成了早期的互联网思维：用效率、产品化和规模化的方式看待问题。',
  },
  {
    stage: '2020',
    title: '从渗透测试到安全视角',
    text: '2020 年，我进入网络安全领域，参与攻防渗透与安全实践。相比开发阶段关注如何构建系统，安全工作让我开始理解系统如何失效，也逐渐形成了更强的风险意识与底线思维。',
  },
  {
    stage: '2024',
    title: '从安全技术到安全管理',
    text: '2024 年后，我的工作重心逐步转向安全管理与项目推进，开始更多面对组织协同、流程治理、资源分配与责任边界等问题。这让我意识到，真正复杂的系统，往往不是代码，而是人、流程与利益关系。',
  },
  {
    stage: '现在',
    title: '在现实经验中继续积累',
    text: '现在，我在安全管理与系统协作中继续积累经验，同时把一部分精力投入到 Web3 安全、AI 工具、投资判断与内容表达中。相比寻找单一答案，我更希望在多个方向之间建立连接，形成可持续的判断与行动能力。',
  },
];

---

<BaseLayout
  title="关于"
  description="Pyrrhax 的个人介绍页，关注网络安全、Web3、AI、投资判断与个人成长。"
>
  <main class="page about-page">
    <section class="about-hero" aria-labelledby="about-title">
      <div class="about-hero-copy">
        <h1 id="about-title">在复杂世界中，<span class="hero-nowrap">建立自己的系统。</span></h1>
      </div>
    </section>

    <section class="about-section" aria-labelledby="profile-heading">
      <div class="section-heading">
        <div>
          <div class="eyebrow">Orientation</div>
          <h2 id="profile-heading">我的坐标</h2>
        </div>
      </div>
      <div class="about-grid profile-grid">
        {profileItems.map((item) => (
          <article class="about-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about-section focus-section" aria-labelledby="focus-heading">
      <div class="section-heading">
        <div>
          <div class="eyebrow">Current Bets</div>
          <h2 id="focus-heading">正在投入的方向</h2>
        </div>
      </div>
      <div class="about-grid focus-grid">
        {focusItems.map((item) => (
          <article class="about-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about-section" aria-labelledby="growth-heading">
      <div class="section-heading">
        <div>
          <div class="eyebrow">Trajectory</div>
          <h2 id="growth-heading">路径演化</h2>
        </div>
      </div>
      <div class="timeline">
        {growthItems.map((item) => (
          <article class="timeline-item">
            <div class="timeline-stage">{item.stage}</div>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="about-section contact-section" aria-labelledby="contact-heading">
      <div class="section-heading">
        <div>
          <div class="eyebrow">Connect</div>
          <h2 id="contact-heading">联系我</h2>
        </div>
      </div>
      <ul class="contact-list">
        <li>如果你也关注技术、Web3、AI、投资与个人成长，欢迎交流。</li>
        <li><a class="contact-email" href="mailto:pyrrhax.hf@gmail.com">pyrrhax.hf@gmail.com</a></li>
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page {
    max-width: min(1120px, calc(100vw - 32px));
    padding-top: 44px;
    overflow-x: hidden;
    overflow-wrap: anywhere;
    font-size: 16px;
    line-height: 1.82;
  }

  .about-hero {
    margin-bottom: 0;
  }

  .about-hero-copy {
    position: relative;
    display: grid;
    align-content: center;
    gap: 16px;
    min-width: 0;
    min-height: 0;
    overflow: visible;
    padding: clamp(34px, 6.5vw, 58px) 0 clamp(30px, 5.4vw, 48px);
  }

  .about-hero-copy::before {
    content: none;
  }

  .about-hero h1 {
    max-width: 860px;
    margin: 0;
    font-size: clamp(2.35rem, 4.8vw, 4.35rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .hero-nowrap {
    display: inline-block;
    overflow-wrap: normal;
    white-space: nowrap;
    word-break: keep-all;
  }

  .about-hero p {
    max-width: 780px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    line-height: 1.9;
  }

  .about-hero .hero-lede {
    max-width: 560px;
    color: var(--muted);
    font-size: clamp(1.12rem, 1.45vw, 1.26rem);
    font-weight: 650;
    line-height: 1.55;
  }

  .about-card,
  .timeline-item {
    border: 1px solid var(--border);
    border-radius: 4px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(248, 251, 252, 0.98)),
      var(--surface);
    box-shadow: 0 10px 28px rgba(16, 35, 42, 0.04);
  }

  .about-card p,
  .timeline-item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.82;
  }

  .about-section {
    margin-top: 52px;
  }

  .about-hero + .about-section {
    margin-top: 42px;
  }

  .focus-section {
    border-top: 1px solid var(--border);
    padding-top: 34px;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .section-heading h2 {
    margin-bottom: 0;
    font-size: clamp(1.65rem, 2.6vw, 2.3rem);
    line-height: 1.25;
  }

  .about-page .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .about-grid {
    display: grid;
    gap: 16px;
  }

  .profile-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .focus-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .focus-grid .about-card {
    border: 0;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    padding: 22px 0;
  }

  .focus-grid .about-card::before {
    content: none;
  }

  .about-card {
    position: relative;
    min-width: 0;
    min-height: 100%;
    overflow: hidden;
    padding: 22px;
  }

  .about-card::before {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: 3px;
    background: var(--accent);
    content: '';
  }

  .about-card h3,
  .timeline-item h3 {
    margin-bottom: 10px;
    font-size: clamp(1.08rem, 1.25vw, 1.22rem);
    line-height: 1.35;
  }

  .timeline {
    display: grid;
    gap: 14px;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 108px minmax(0, 1fr);
    gap: 18px;
    padding: 22px;
  }

  .timeline-stage {
    padding-top: 3px;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: clamp(1rem, 1.25vw, 1.12rem);
    font-weight: 760;
    line-height: 1.35;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }

  .contact-section {
    border-top: 1px solid var(--border);
    padding-top: 34px;
  }

  .contact-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-list li {
    position: relative;
    padding-left: 22px;
    color: #3f4a50;
    font-size: 1rem;
    line-height: 1.8;
  }

  .contact-list li::before {
    position: absolute;
    top: 0.78em;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--accent);
    content: '';
  }

  .about-hero h1,
  .about-hero p,
  .about-card,
  .timeline-item,
  .contact-section {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .contact-email {
    color: #3f4a50;
    font-weight: 650;
    text-decoration-color: color-mix(in srgb, var(--muted) 32%, transparent);
    text-underline-offset: 4px;
  }

  .contact-email:hover {
    color: var(--text);
    text-decoration-color: color-mix(in srgb, var(--accent) 48%, transparent);
  }

  @media (max-width: 860px) {
    .about-page {
      padding-top: 30px;
    }

    .profile-grid,
    .focus-grid {
      grid-template-columns: 1fr;
    }

    .about-hero-copy {
      min-height: 0;
    }

  }

  @media (max-width: 620px) {
    .about-hero {
      margin-bottom: 0;
    }

    .about-hero h1 {
      font-size: clamp(2rem, 8vw, 2.45rem);
    }

    .about-hero p {
      font-size: 1rem;
    }

    .timeline-item {
      grid-template-columns: 1fr;
    }

    .timeline-item {
      gap: 8px;
    }

    .timeline-stage {
      font-size: 1rem;
    }
  }
</style>
