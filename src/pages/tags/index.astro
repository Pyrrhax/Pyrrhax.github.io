---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTerms, getPosts, tagUrl } from '../../lib/posts';

const posts = await getPosts();
const tags = getAllTerms(posts, 'tags');
---

<BaseLayout title="标签">
  <main class="page">
    <section class="hero plain-hero">
      <div class="eyebrow">Tags</div>
      <h1>标签</h1>
    </section>
    <div class="term-grid">
      {tags.map(([tag, count]) => (
        <a href={tagUrl(tag)}>
          <span>{tag}</span>
          <strong>{count}</strong>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
