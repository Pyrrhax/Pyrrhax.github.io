---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTerms, getPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return getAllTerms(posts, 'tags').map(([tag]) => ({
    params: { tag },
    props: { tag, posts: posts.filter((post) => post.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：${tag}`}>
  <main class="page">
    <section class="hero plain-hero">
      <div class="eyebrow">Tag</div>
      <h1>{tag}</h1>
    </section>
    <section class="post-list">
      {posts.map((post) => <PostCard post={post} />)}
    </section>
  </main>
</BaseLayout>
