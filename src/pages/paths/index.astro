---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { columnUrl, getAllColumns, getPosts } from '../../lib/posts';

const posts = await getPosts();
const columns = getAllColumns(posts);
---

<BaseLayout title="专栏">
  <main class="page">
    <section class="hero plain-hero">
      <div class="eyebrow">Columns</div>
      <h1>专栏</h1>
    </section>

    <section class="topic-grid" aria-label="专栏列表">
      {columns.map((item) => (
        <a class="topic-card" href={columnUrl(item.slug)}>
          <span>{item.title}</span>
          <p>{item.description}</p>
          <strong>{item.count} 篇 · {item.label}</strong>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
