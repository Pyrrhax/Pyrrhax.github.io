---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { columnUrl, getAllColumns, getPosts } from '../../lib/posts';

const posts = await getPosts();
const columns = getAllColumns(posts);
---

<BaseLayout title="专栏">
  <main class="page">
    <section class="hero">
      <div class="eyebrow">Columns</div>
      <h1>专栏</h1>
      <p>把散落在旧博客和公众号里的文章按连续问题重新编组。专栏不等同于标签：它更像一条可读完、可回看的知识线。</p>
    </section>

    <section class="topic-grid" aria-label="专栏列表">
      {columns.map((item) => (
        <a class="topic-card" href={columnUrl(item.slug)}>
          <span>{item.title}</span>
          <p>{item.description}</p>
          <strong>{item.count} 篇 · {item.label}</strong>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
