---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllColumns, getPosts, getPostsByColumn, getColumnDefinition } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return getAllColumns(posts).map((column) => ({
    params: { series: column.slug },
    props: { slug: column.slug },
  }));
}

const { slug } = Astro.props;
const posts = await getPosts();
const column = getColumnDefinition(slug);
const columnPosts = getPostsByColumn(slug, posts);
---

<BaseLayout title={column?.title || '专栏'}>
  <main class="page">
    <section class="hero plain-hero">
      <div class="eyebrow">Columns</div>
      <h1>{column?.title}</h1>
      <p>{column?.description}</p>
    </section>

    <section class="home-section" aria-label="专栏文章">
      <div class="section-heading">
        <div>
          <div class="eyebrow">{column?.label}</div>
          <h2>{columnPosts.length} 篇文章</h2>
        </div>
        <a class="text-link" href="/paths/">全部专栏</a>
      </div>
      <div class="post-list column-post-list">
        {columnPosts.map((post, index) => (
          <div class="column-post-row">
            <span class="column-index">{String(index + 1).padStart(2, '0')}</span>
            <PostCard post={post} />
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
