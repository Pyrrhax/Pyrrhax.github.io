---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categoryUrl, getAllTerms, getPosts } from '../../lib/posts';

const posts = await getPosts();
const categories = getAllTerms(posts, 'categories');
---

<BaseLayout title="分类">
  <main class="page">
    <section class="hero">
      <div class="eyebrow">Categories</div>
      <h1>分类</h1>
      <p>沿用旧站的内容分类，并为后续写作保留扩展空间。</p>
    </section>
    <div class="term-grid">
      {categories.map(([category, count]) => <a href={categoryUrl(category)}>{category} · {count}</a>)}
    </div>
  </main>
</BaseLayout>
