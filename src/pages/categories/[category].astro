---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTerms, getPosts, postUrl } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return getAllTerms(posts, 'categories').map(([category]) => ({
    params: { category },
    props: { category, posts: posts.filter((post) => post.data.categories.includes(category)) },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`分类：${category}`}>
  <main class="page">
    <section class="hero">
      <div class="eyebrow">Category</div>
      <h1>{category}</h1>
    </section>
    <section class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <div>
            <h2><a href={postUrl(post)}>{post.data.title}</a></h2>
            {post.data.description && <p class="lede">{post.data.description}</p>}
          </div>
          <time class="meta" datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('zh-CN')}</time>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
