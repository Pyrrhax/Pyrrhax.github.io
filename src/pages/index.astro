---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  columnUrl,
  getAllColumns,
  getAllTopics,
  getFeaturedPosts,
  getPosts,
  postTopic,
  postUrl,
  topicLabel,
  topicUrl,
} from '../lib/posts';

const posts = await getPosts();
const topics = await getAllTopics(posts);
const featuredPosts = await getFeaturedPosts();
const securityPosts = posts.filter((post) => postTopic(post) === 'security');
const programmingPosts = posts.filter((post) => postTopic(post) === 'programming');
const toolingPosts = posts.filter((post) => postTopic(post) === 'tooling');
const thinkingPosts = posts.filter((post) => postTopic(post) === 'thinking');
const aiPosts = posts.filter((post) => postTopic(post) === 'ai');
const web3Posts = posts.filter((post) => postTopic(post) === 'web3');
const featured =
  featuredPosts.length > 0
    ? featuredPosts.slice(0, 6)
    : [
        ...securityPosts.slice(0, 3),
        ...programmingPosts.slice(0, 1),
        ...toolingPosts.slice(0, 1),
        ...thinkingPosts.slice(0, 1),
    ].slice(0, 6);
const heroPosts = featured.slice(0, 3);
const columns = getAllColumns(posts).slice(0, 4);

const valueThemes = [
  {
    key: 'security',
    label: '安全研究主线',
    count: securityPosts.length,
    text: '博客最核心的内容资产：从漏洞原理、Web 攻防、内网、靶场到工具链，适合按路径连续学习。',
    accent: 'blue',
  },
  {
    key: 'web3',
    label: 'Web3 基础判断',
    count: web3Posts.length,
    text: '把链上链下、DEX、共识、以太坊、稳定币、Layer2 等概念整理成可理解、可判断的入门地图。',
    accent: 'gold',
  },
  {
    key: 'ai',
    label: 'AI 与认知推演',
    count: aiPosts.length,
    text: '关注 AI 时代的底层能力、群智涌现、提示词工程、安全风险和人机协作方式。',
    accent: 'red',
  },
  {
    key: 'programming',
    label: '工程能力底座',
    count: programmingPosts.length,
    text: '保留 Java、汇编、算法题和源码理解等基础工程内容，为安全研究提供实现层支撑。',
    accent: 'green',
  },
];

const columnImages = [
  'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1400&q=80',
  'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1400&q=80',
  'https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=1400&q=80',
  'https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1400&q=80',
];

const heroImages = [
  'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1600&q=80',
  'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1600&q=80',
  'https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=1600&q=80',
];

const columnFallbacks = [
  securityPosts.slice(0, 3),
  posts.filter((post) => post.data.tags.includes('Spring') || post.data.tags.includes('Java')).slice(0, 3),
  posts.filter((post) => post.data.tags.includes('靶机') || post.data.tags.includes('内网')).slice(0, 3),
  posts.filter((post) => postTopic(post) === 'ai' || postTopic(post) === 'thinking').slice(0, 3),
];

const paths = columns.slice(0, 4).map((column, index) => ({
  title: column.shortTitle,
  kicker: column.label,
  text: column.description,
  href: columnUrl(column.slug),
  image: columnImages[index % columnImages.length],
  posts: posts.filter(column.match).slice(0, 3),
}));

if (paths.length === 0) {
  paths.push(
    ...['渗透测试起步', 'Java / Spring 漏洞线', '靶场与实战复盘'].map((title, index) => ({
      title,
      kicker: ['Pentest Track', 'Framework Security', 'Practice Notes'][index],
      text: ['从 Kali、信息收集、漏洞利用、内网和 Cobalt Strike 串起攻防基本路线。', '围绕 Spring 参数绑定、SpEL、CVE 分析，把单篇漏洞复盘变成专栏学习链。', '把靶机、专项靶场和内网笔记变成可反复练习的训练路线。'][index],
      href: '/paths/',
      image: columnImages[index],
      posts: columnFallbacks[index],
    })),
  );
}

const formatDate = (date: Date) => date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout title="Pyrrhax">
  <main class="page home-product" id="top">
    <section class="home-hero-grid" aria-label="首页">
      <div class="home-hero-main">
        {heroPosts.map((post, index) => (
          <article
            class="hero-slide"
            data-hero-slide={String(index)}
            hidden={index !== 0}
            style={`background-image: linear-gradient(90deg, rgba(10,30,34,.92), rgba(15,70,76,.58)), url("${heroImages[index % heroImages.length]}")`}
          >
            <p class="kicker">质量 {post.data.qualityScore}/100 · {topicLabel(postTopic(post))} · #{index + 1}</p>
            <h1>{post.data.title}</h1>
            <p class="lead">{post.data.description || `标签：${post.data.tags.slice(0, 4).join('、') || '技术笔记'}`}</p>
            <div class="hero-actions">
              <a class="button primary" href={postUrl(post)}>阅读这篇</a>
              <a class="button" href="#themes">看核心主题</a>
              <a class="button" href="#articles">看精选文章</a>
            </div>
          </article>
        ))}
        <div class="hero-controls" aria-label="首屏精选文章轮播控制">
          {heroPosts.map((post, index) => (
            <button
              class="path-dot"
              type="button"
              data-hero-target={String(index)}
              aria-label={`查看${post.data.title}`}
              aria-pressed={index === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      </div>

      <div class="signal-panel">
        <div class="stat-row">
          <div class="stat"><strong>{posts.length}</strong><span>历史文章</span></div>
          <div class="stat"><strong>{topics.length}</strong><span>内容主题</span></div>
        </div>
        <div class="module">
          <h2>质量排序</h2>
          <p>所有文章都写入 0-100 的质量评分；精选文章自动取排名前 6，首屏大屏展示排名前 3。</p>
        </div>
        <div class="module">
          <h2>内容秩序</h2>
          <p>首页只展示最有价值的主题和路径；完整主题索引仍在顶部导航里。</p>
        </div>
      </div>
    </section>

    <section id="themes" class="product-section">
      <div class="product-section-head">
        <div>
          <h2>高价值主题</h2>
          <p>不是把所有分类都摊开，而是先给读者 4 个最值得投入时间的阅读方向。</p>
        </div>
        <a class="button" href="/topics/">全部主题</a>
      </div>
      <div class="pillars">
        {valueThemes.map((theme) => (
          <a class={`pillar ${theme.accent}`} href={topicUrl(theme.key)}>
            <div>
              <h3>{theme.label}</h3>
              <p>{theme.text}</p>
            </div>
            <div class="pillar-count">
              <span>{theme.count} 篇</span>
              <span>{topicLabel(theme.key)}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section id="paths" class="product-section">
      <div class="product-section-head">
        <div>
          <h2>推荐专栏</h2>
          <p>每个专栏独立成一张封面，右侧只显示这个专栏的三篇文章。</p>
        </div>
        <a class="button" href="/paths/">全部专栏</a>
      </div>
      <div class="path-showcase">
        {paths.map((path, index) => (
          <div class="path-slide" data-path-slide={String(index)} hidden={index !== 0}>
            <a
              class="path-cover"
              href={path.href}
              style={`background-image: linear-gradient(180deg, rgba(16,39,44,.04), rgba(16,39,44,.9)), url("${path.image}")`}
            >
              <p class="kicker">{path.kicker}</p>
              <h2>{path.title}</h2>
              <p>{path.text}</p>
            </a>
            <article class="path-card">
              <div class="mini-list">
                {path.posts.map((post) => (
                  <a href={postUrl(post)}>
                    <strong>{post.data.title}</strong>
                    <span>{post.data.description || `标签：${post.data.tags.slice(0, 4).join('、') || '技术笔记'}`}</span>
                  </a>
                ))}
              </div>
            </article>
          </div>
        ))}
        <div class="path-controls" aria-label="推荐专栏轮播控制">
          <div class="path-dots">
            {paths.map((path, index) => (
              <button
                class="path-dot"
                type="button"
                data-path-target={String(index)}
                aria-label={`查看${path.title}`}
                aria-pressed={index === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
          <div class="path-arrows">
            <button class="icon-button" type="button" data-path-prev aria-label="上一个专栏">‹</button>
            <button class="icon-button" type="button" data-path-next aria-label="下一个专栏">›</button>
          </div>
        </div>
      </div>
    </section>

    <section id="articles" class="product-section">
      <div class="product-section-head">
        <div>
          <h2>精选文章展示</h2>
          <p>按内容价值挑出的 6 篇文章，优先展示能代表博客深度和学习路径的节点。</p>
        </div>
        <a class="button" href="/archives/">全部文章</a>
      </div>
      <div class="articles">
        {featured.map((post) => (
          <article class="article-card">
            <a class="tag" href={topicUrl(postTopic(post))}>{topicLabel(postTopic(post))}</a>
            <h3><a href={postUrl(post)}>{post.data.title}</a></h3>
            <p>{post.data.description || `标签：${post.data.tags.slice(0, 4).join('、') || '技术笔记'}`}</p>
            <div class="article-meta">
              <span>质量 {post.data.qualityScore}/100</span>
              <span>{formatDate(post.data.date)}</span>
              {post.data.tags.slice(0, 2).map((tag) => <span>{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script>
    const heroSlides = [...document.querySelectorAll<HTMLElement>('[data-hero-slide]')];
    const heroDots = [...document.querySelectorAll<HTMLButtonElement>('[data-hero-target]')];
    const pathSlides = [...document.querySelectorAll<HTMLElement>('[data-path-slide]')];
    const pathDots = [...document.querySelectorAll<HTMLButtonElement>('[data-path-target]')];
    const prevPathButton = document.querySelector<HTMLButtonElement>('[data-path-prev]');
    const nextPathButton = document.querySelector<HTMLButtonElement>('[data-path-next]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeHeroIndex = 0;
    let activePathIndex = 0;

    const showHero = (index: number) => {
      if (!heroSlides.length) return;
      activeHeroIndex = (index + heroSlides.length) % heroSlides.length;
      heroSlides.forEach((slide, slideIndex) => {
        slide.hidden = slideIndex !== activeHeroIndex;
      });
      heroDots.forEach((dot, dotIndex) => {
        dot.setAttribute('aria-pressed', String(dotIndex === activeHeroIndex));
      });
    };

    const showPath = (index: number) => {
      if (!pathSlides.length) return;
      activePathIndex = (index + pathSlides.length) % pathSlides.length;
      pathSlides.forEach((slide, slideIndex) => {
        slide.hidden = slideIndex !== activePathIndex;
      });
      pathDots.forEach((dot, dotIndex) => {
        dot.setAttribute('aria-pressed', String(dotIndex === activePathIndex));
      });
    };

    pathDots.forEach((dot) => {
      dot.addEventListener('click', () => showPath(Number(dot.dataset.pathTarget || 0)));
    });

    heroDots.forEach((dot) => {
      dot.addEventListener('click', () => showHero(Number(dot.dataset.heroTarget || 0)));
    });

    prevPathButton?.addEventListener('click', () => showPath(activePathIndex - 1));
    nextPathButton?.addEventListener('click', () => showPath(activePathIndex + 1));

    if (!reduceMotion) {
      window.setInterval(() => showHero(activeHeroIndex + 1), 6200);
      window.setInterval(() => showPath(activePathIndex + 1), 7200);
    }
  </script>
</BaseLayout>
