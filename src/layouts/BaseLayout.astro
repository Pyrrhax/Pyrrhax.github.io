---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pyrrhax',
  description = 'Security, programming, and notes by Pyrrhax.',
} = Astro.props;
const pageTitle = title === 'Pyrrhax' ? title : `${title} | Pyrrhax`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicons/favicon.ico" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav" aria-label="主导航">
          <a class="brand" href="/">Pyrrhax</a>
          <div class="nav-links">
            <a href="/">首页</a>
            <a href="/topics/" data-tooltip="按方向浏览全部文章">主题</a>
            <a href="/paths/" data-tooltip="按一条连续路径系统阅读">专栏</a>
            <a href="/tags/" data-tooltip="查找具体技术点">标签</a>
            <a href="/about/">关于</a>
          </div>
        </nav>
      </header>
      <slot />
      <footer class="site-footer">
        <div>© {new Date().getFullYear()} Pyrrhax. Built with Astro.</div>
      </footer>
    </div>
  </body>
</html>
